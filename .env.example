# ── Paste these into Vercel → Project → Settings → Environment Variables (Production)
# Or copy to a local `.env` file (never commit real secrets).

NODE_ENV=production

# Required for login, API, Postgres
DATABASE_URL=
JWT_SECRET=

# Optional: extra allowed browser origins (comma-separated).
# Your *.vercel.app URL is added automatically from VERCEL_URL on Vercel.
# ALLOWED_ORIGINS=https://fitmunch.com.au,https://www.fitmunch.com.au

# Stripe (optional)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# Receipt AI / meal planner (optional)
# ANTHROPIC_API_KEY=

# Instagram posting (optional)
# INSTAGRAM_ACCESS_TOKEN=
# IG_BUSINESS_ACCOUNT_ID=
