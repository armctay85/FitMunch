# ── Copy to `.env` locally (never commit). Sync to Vercel: `npm run env:vercel`
#
# Optional (only for npm run env:vercel — not used by the Node app at runtime):
# VERCEL_TOKEN=
# VERCEL_TARGET_PROJECT=fit-munch
# VERCEL_TEAM_ID=

NODE_ENV=production

# Required for login, API, Postgres
DATABASE_URL=
JWT_SECRET=

# Optional: extra allowed browser origins (comma-separated).
# Your *.vercel.app URL is added automatically from VERCEL_URL on Vercel.
# ALLOWED_ORIGINS=https://fitmunch.com.au,https://www.fitmunch.com.au

# Stripe (optional)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# Receipt AI / meal planner (optional)
# ANTHROPIC_API_KEY=

# AI coach (preferred: OpenAI). If both keys are set, OpenAI wins.
# OPENAI_API_KEY=
# OPENAI_CHAT_MODEL=gpt-4o-mini
# AI_FREE_MONTHLY_LIMIT=10

# Instagram posting (optional)
# INSTAGRAM_ACCESS_TOKEN=
# IG_BUSINESS_ACCOUNT_ID=
